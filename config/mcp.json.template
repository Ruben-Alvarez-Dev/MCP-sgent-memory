{
  "mcpServers": {
    "automem": {
      "command": "{{DIR}}/.venv/bin/python3",
      "args": ["-u", "{{DIR}}/src/automem/server/main.py"],
      "env": {
        "PYTHONPATH": "{{DIR}}/src",
        "MEMORY_SERVER_DIR": "{{DIR}}",
        "QDRANT_URL": "{{QDRANT_URL}}",
        "EMBEDDING_BACKEND": "llama_server",
        "LLAMA_SERVER_URL": "{{LLAMA_SERVER_URL}}",
        "EMBEDDING_DIM": "1024"
      },
      "tags": ["memory", "ingest"],
      "disabled": false
    },
