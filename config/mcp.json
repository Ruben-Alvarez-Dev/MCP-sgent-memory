{
  "mcpServers": {
    "automem": {
      "command": "python3",
      "args": ["-u", "src/automem/server/main.py"],
      "env": {
        "OLLAMA_URL": "${OLLAMA_URL:-http://127.0.0.1:11434}",
        "QDRANT_URL": "${QDRANT_URL:-http://127.0.0.1:6333}",
        "EMBEDDING_MODEL": "${EMBEDDING_MODEL:-bge-m3}"
      },
      "tags": ["memory", "ingest", "always-on"]
    },
    "autodream": {
      "command": "python3",
      "args": ["-u", "src/autodream/server/main.py"],
      "env": {
        "OLLAMA_URL": "${OLLAMA_URL:-http://127.0.0.1:11434}",
        "QDRANT_URL": "${QDRANT_URL:-http://127.0.0.1:6333}",
        "SUMMARY_MODEL": "${SUMMARY_MODEL:-qwen2.5:7b}"
      },
      "tags": ["memory", "consolidation"]
    },
    "vk-cache": {
      "command": "python3",
      "args": ["-u", "src/vk-cache/server/main.py"],
      "env": {
        "QDRANT_URL": "${QDRANT_URL:-http://127.0.0.1:6333}",
        "VK_MAX_TOKENS": "48000"
      },
      "tags": ["memory", "retrieval"]
    },
    "search-mcp": {
      "command": "node",
      "args": ["${HOME}/MCP-servers/MCP-search-server/build/index.js"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "tags": ["search"]
    }
  }
}
