# Memory MCP Servers Configuration
#
# All environment variables for the complete memory stack.
# Copy to .env and adjust paths/URLs as needed.

# ── Shared Infrastructure ──────────────────────────────────────────

# Ollama (local embeddings + LLM)
OLLAMA_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=nomic-embed-text
SUMMARY_MODEL=qwen2.5:7b

# Qdrant (vector store — runs from MCP-servers/shared/qdrant/)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=automem
CONV_COLLECTION=conversations
MEM0_COLLECTION=mem0_memories
EMBEDDING_DIM=768

# ── AutoMem (L0/L1/L2 Ingest Daemon) ──────────────────────────────

AUTOMEM_JSONL=~/.memory/raw_events.jsonl
AUTOMEM_PROMOTE_EVERY=10

# ── AutoDream (L3/L4 Consolidation Daemon) ────────────────────────

DREAM_PATH=~/.memory/dream
DREAM_PROMOTE_L1=10
DREAM_PROMOTE_L2=3600
DREAM_PROMOTE_L3=86400
DREAM_PROMOTE_L4=604800

# ── vk-cache (L5 Context Assembly) ────────────────────────────────

VK_MIN_SCORE=0.3
VK_MAX_ITEMS=8
VK_MAX_TOKENS=8000

# ── Mem0 Bridge (L1 Semantic) ─────────────────────────────────────

MEM0_USER=ruben
MEM0_ENABLED=true

# ── Engram Bridge (L3 Decisions) ──────────────────────────────────

ENGRAM_PATH=~/.memory/engram

# ── Agent Configuration ───────────────────────────────────────────

DEFAULT_AGENT_ID=default
DEFAULT_SCOPE=session
